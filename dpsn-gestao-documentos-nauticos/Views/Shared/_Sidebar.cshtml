@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<div id="sidebarOverlay" class="fixed inset-0 bg-slate-900/40 z-40 hidden md:hidden transition-opacity duration-300 opacity-0"></div>

<aside id="sidebar" class="fixed inset-y-0 left-0 md:sticky md:top-0 z-50 flex flex-col h-full bg-slate-800 text-white transition-all duration-300 ease-in-out
             -translate-x-full md:translate-x-0
             html-sidebar-collapsed:w-20 w-64 font-['Poppins']">

    <div class="flex flex-col justify-center h-20 px-6 border-b border-slate-500/30">
        <div class="flex items-center justify-between whitespace-nowrap overflow-hidden">
            <div class="flex flex-col">
                <span class="font-bold text-white tracking-wide text-lg leading-tight">DPSN</span>
                <span class="text-[11px] text-slate-400 tracking-normal font-light">Gestão de Documentos Náuticos</span>
            </div>
            <button id="closeSidebarMobileBtn" class="md:hidden text-slate-400 hover:text-white p-1">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
    </div>

    <nav class="flex-1 py-6 px-4 space-y-1 overflow-y-auto scrollbar-none">

        <span class="sidebar-text text-[10px] font-semibold uppercase tracking-wider text-slate-500 block px-3 mb-3 transition-opacity duration-200">
            Navegação
        </span>

        <a href="@Url.Action("Index", "Home")"
           class="flex items-center gap-3.5 px-3 py-3 rounded-md text-white bg-sky-800 transition-colors group relative font-medium text-sm">
            <div class="w-5 flex justify-center text-base min-w-[20px]">
                <i class="fa-solid fa-table-columns"></i>
            </div>
            <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Painel de Controle</span>
        </a>

        <a href="@Url.Action("Index", "Documentos")"
           class="flex items-center gap-3.5 px-3 py-3 rounded-md text-slate-300 hover:bg-slate-700/50 hover:text-white transition-colors group text-sm font-normal">
            <div class="w-5 flex justify-center text-base min-w-[20px] text-slate-400 group-hover:text-slate-200">
                <i class="fa-regular fa-file-lines"></i>
            </div>
            <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Documentos</span>
        </a>

        @if (!User.IsInRole("Estaleiro"))
        {
            <a href="@Url.Action("Index", "Estaleiro")"
            class="flex items-center gap-3.5 px-3 py-3 rounded-md text-slate-300 hover:bg-slate-700/50 hover:text-white transition-colors group text-sm font-normal">
                <div class="w-5 flex justify-center text-base min-w-[20px] text-slate-400 group-hover:text-slate-200">
                    <i class="fa-solid fa-warehouse"></i>
                </div>
                <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Estaleiros</span>
            </a>
        }

        <a href="@Url.Action("Index", "Embarcacoes")"
           class="flex items-center gap-3.5 px-3 py-3 rounded-md text-slate-300 hover:bg-slate-700/50 hover:text-white transition-colors group text-sm font-normal">
            <div class="w-5 flex justify-center text-base min-w-[20px] text-slate-400 group-hover:text-slate-200">
                <i class="fa-solid fa-anchor"></i>
            </div>
            <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Embarcações</span>
        </a>

        @* @if (!User.IsInRole("Estaleiro"))
        {
            <a href="@Url.Action("Index", "Audits")"
               class="flex items-center gap-3.5 px-3 py-3 rounded-md text-slate-300 hover:bg-slate-700/50 hover:text-white transition-colors group text-sm font-normal">
                <div class="w-5 flex justify-center text-base min-w-[20px] text-slate-400 group-hover:text-slate-200">
                    <i class="fa-solid fa-clipboard-check"></i>
                </div>
                <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Auditorias & Logs</span>
            </a>
        } *@

        <a href="@Url.Action("Settings", "Home")"
           class="flex items-center gap-3.5 px-3 py-3 rounded-md text-slate-300 hover:bg-slate-700/50 hover:text-white transition-colors group text-sm font-normal">
            <div class="w-5 flex justify-center text-base min-w-[20px] text-slate-400 group-hover:text-slate-200">
                <i class="fa-solid fa-sliders"></i>
            </div>
            <span class="sidebar-text transition-opacity duration-200 overflow-hidden whitespace-nowrap">Configurações</span>
        </a>
    </nav>

    @if (SignInManager.IsSignedIn(User))
    {
        <div class="p-4 border-t border-slate-500/30 bg-slate-900/20">
            <div class="flex items-center justify-between overflow-hidden">
                <div class="flex items-center gap-3 overflow-hidden">
                    <div class="w-9 h-9 min-w-[36px] bg-sky-800 rounded-full flex items-center justify-center text-white font-bold text-sm border border-slate-500/40 uppercase">
                        @(User.Identity?.Name?.Substring(0, 1) ?? "U")
                    </div>
                    <div class="sidebar-text flex flex-col transition-opacity duration-200 overflow-hidden whitespace-nowrap">
                        <span class="text-xs font-medium text-white truncate max-w-[140px]">@User.Identity?.Name</span>
                        <span class="text-[10px] text-slate-400 font-light truncate">
                            @if (User.IsInRole("Admin"))
                            {
                                <text>Administrador</text>
                            }
                            else if (User.IsInRole("Tecnologo"))
                            {

                                <text>Tecnólogo Naval</text>
                            }
                            else if (User.IsInRole("Estaleiro"))
                            {

                                <text>Usuário Estaleiro</text>
                            }
                        </span>
                    </div>
                </div>

                <a href="@Url.Action("Logout", "Accounts")" class="sidebar-text text-slate-400 hover:text-rose-400 p-1.5 transition-colors" title="Sair do sistema">
                    <i class="fa-solid fa-arrow-right-from-bracket text-sm"></i>
                </a>
            </div>
        </div>
    }
</aside>

<style>
    .sidebar-is-collapsed #sidebar {
        width: 5rem;
    }

    .sidebar-is-collapsed .sidebar-text {
        display: none;
        opacity: 0;
    }
</style>