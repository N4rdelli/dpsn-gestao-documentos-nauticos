@model IEnumerable<dpsn_gestao_documentos_nauticos.Models.Embarcacao>

@{
    ViewData["Title"] = "Lista de Embarcações";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Gerenciamento de Embarcações</h2>
        <a asp-action="Insert" class="btn btn-primary">+ Nova Embarcação</a>
    </div>
    <hr />

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Inscrição</th>
                <th>Tipo</th>
                <th>ID Estaleiro</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.NumInscricao</td>
                        <td>@item.TipoEmbarcacao</td>
                        <td>@(item.EstaleiroId?.ToString() ?? "Não Informado")</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <!-- Botão Editar (Passa a Hash Hexadecimal do Mongo) -->
                                <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>

                                <!-- Formulário de Exclusão Segura -->
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Tem certeza que deseja deletar do MongoDB?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="idEmbarcacao" value="@item.Id" />
                                    <input type="hidden" name="estaleiroId" value="@item.EstaleiroId" />
                                    <button type="submit" class="btn btn-danger btn-sm">Excluir</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">Nenhuma embarcação localizada no banco de dados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>