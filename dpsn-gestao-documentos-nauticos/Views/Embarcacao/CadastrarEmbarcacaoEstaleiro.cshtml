@model dpsn_gestao_documentos_nauticos.ViewModel.EmbarcacaoViewModel

@{
    ViewData["Title"] = "Cadastrar Embarcação";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Cadastrar Nova Embarcação</h2>
    <p class="text-muted">A embarcação será vinculada automaticamente ao seu estaleiro.</p>
    <hr />

    <form asp-action="Insert" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NumeroInscricao" class="form-label"></label>
            <input asp-for="NumeroInscricao" class="form-control" />
            <span asp-validation-for="NumeroInscricao" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Tipo" class="form-label"></label>
            <select asp-for="Tipo" class="form-select">
                <option value="">Selecione o tipo...</option>
                <option value="Lancha">Lancha</option>
                <option value="Veleiro">Veleiro</option>
                <option value="Iate">Iate</option>
                <option value="JetSki">Jet Ski</option>
            </select>
            <span asp-validation-for="Tipo" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Cadastrar Embarcação</button>
        <a asp-controller="Inicio" asp-action="InicioEstaleiro" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}