@model IEnumerable<dpsn_gestao_documentos_nauticos.ViewModel.EmbarcacaoViewModel>

@{
    ViewData["Title"] = "Embarcações Cadastradas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-ship"></i> Frota de Embarcações</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Cadastrar Nova Embarcação
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Estaleiro (Construtor)</th>
                        <th>Tipo</th>
                        <th>Área de Navegação</th>
                        <th>Comprimento</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Nenhum registro de embarcação encontrado no banco MongoDB.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Nome</strong></td>
                                <td><span class="badge bg-secondary">@item.NomeEstaleiro</span></td>
                                <td>@item.TipoEmbarcacao</td>
                                <td>@item.AreaNavegacaoTipoServico</td>
                                <td>@item.ComprimentoTotal.ToString("F2") m</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.IdEmbarcacao" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IdEmbarcacao" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Excluir
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>