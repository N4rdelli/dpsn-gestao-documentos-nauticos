@model IEnumerable<dpsn_gestao_documentos_nauticos.Models.Estaleiro>

@{
    ViewData["Title"] = "Estaleiros Parceiros";
}

<div class="mb-8 flex flex-row items-center justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-slate-950 tracking-tight">Menu Estaleiros</h1>
        <p class="text-sm text-slate-500">Gerencie os estaleiros navais parceiros credenciados no ecossistema DPSN.</p>
    </div>
    <div>
        <a asp-action="Create" class="inline-flex items-center space-x-2 px-4 py-2.5 text-sm font-medium text-white bg-sky-800 hover:bg-sky-900 active:bg-sky-900 rounded-md shadow-sm hover:shadow transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>Criar Estaleiro</span>
        </a>
    </div>
</div>

@if (TempData["MensagemSucesso"] != null)
{
    <div class="mb-6 p-4 bg-emerald-50 border-l-4 border-emerald-500 rounded-r-lg text-emerald-700 flex items-center space-x-2 shadow-sm">
        <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-sm font-medium">@TempData["MensagemSucesso"]</span>
    </div>
}

@if (TempData["MensagemErro"] != null)
{
    <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 rounded-r-lg text-red-700 flex items-center space-x-2 shadow-sm">
        <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-sm font-medium">@TempData["MensagemErro"]</span>
    </div>
}

<div class="bg-white rounded-xl border border-slate-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-100 text-xs font-semibold text-slate-600 uppercase tracking-wider">
                    <th class="px-6 py-4">Estaleiro</th>
                    <th class="px-6 py-4">CNPJ</th>
                    <th class="px-6 py-4">Contato</th>
                    <th class="px-6 py-4">Localização</th>
                    <th class="px-6 py-4">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-slate-400">
                            Nenhum estaleiro parceiro cadastrado até o momento.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-3">
                                    <div class="w-9 h-9 bg-blue-50 text-slate-600 rounded-lg flex items-center justify-center font-bold text-sm uppercase shrink-0 border border-blue-100">
                                        @(item.NomeFantasia?.Substring(0, 2) ?? "ES")
                                    </div>
                                    <div>
                                        <div class="font-semibold text-slate-950">@item.NomeFantasia</div>
                                        <div class="text-xs text-slate-400 truncate max-w-[200px]">@item.RazaoSocial</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-slate-600">
                                @item.Cnpj
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col space-y-0.5">
                                    <span class="text-slate-800 font-medium">@item.Email</span>
                                    <span class="text-xs text-slate-400">@item.Telefone</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-600">
                                <div class="flex flex-col">
                                    <span>@item.Endereco.Cidade - @item.Endereco.Estado</span>
                                    <span class="text-xs text-slate-400">CEP: @item.Endereco.Cep</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <div class="inline-flex items-center space-x-1.5">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="p-1.5 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-md transition-colors" title="Visualizar Detalhes">
                                        <i class="fa-regular fa-eye text-sm"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="p-1.5 text-blue-500 hover:text-sky-600 hover:bg-sky-100 rounded-md transition-colors" title="Editar">
                                        <i class="fa-regular fa-pen-to-square text-sm"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="p-1.5 text-rose-500 hover:text-rose-700 hover:bg-rose-100 rounded-md transition-colors" title="Excluir">
                                        <i class="fa-regular fa-trash-can text-sm"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>