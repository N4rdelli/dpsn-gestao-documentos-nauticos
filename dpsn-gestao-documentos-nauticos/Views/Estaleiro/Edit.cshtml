@model dpsn_gestao_documentos_nauticos.ViewModel.EstaleiroViewModel;

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Estaleiro</h4>
<hr />
<div class="row">
    <div class="col-md-4">
		@if (TempData["MensagemErro"] != null)
		{
			<div class="alert alert-danger alert-dismissible fade show" role="alert">
				<i class="bi bi-exclamation-triangle-fill me-2"></i>
				@TempData["MensagemErro"]
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		}
        <form asp-action="Edit" asp-controller="Estaleiro">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
			<div class="form-group">
				<label asp-for="NomeFantasia">Nome Fantasia</label>
				<input type="text" asp-for="NomeFantasia" class="form-control" />
				
				<label asp-for="RazaoSocial">Razão Social</label>
				<input type="text" asp-for="RazaoSocial" class="form-control" />

				<label asp-for="Cnpj">CNPJ</label>
				<input type="text" asp-for="Cnpj" class="form-control" />
			</div>
			<div class="form-group">
				<label asp-for="Email">Email</label>
				<input type="email" asp-for="Email" class="form-control" />

				<label asp-for="Telefone">Telefone</label>
				<input type="text" asp-for="Telefone" class="form-control" />
			</div>
			<div class="form-group">
				<label asp-for="Cep">CEP</label>
				<input type="text" asp-for="Cep" class="form-control" />

				<label asp-for="Logradouro">Logradouro</label>
				<input type="text" asp-for="Logradouro" class="form-control" />

				<label asp-for="Numero">Número</label>
				<input type="text" asp-for="Numero" class="form-control" />

				<label asp-for="Complemento">Complemento</label>
				<input type="text" asp-for="Complemento" class="form-control" />

			</div>
			<div class="form-group">
				<label asp-for="Bairro">Bairro</label>
				<input type="text" asp-for="Bairro" class="form-control" />
				<label asp-for="Cidade">Cidade</label>
				<input type="text" asp-for="Cidade" class="form-control" />
				<label asp-for="Estado">Estado</label>
				<input type="text" asp-for="Estado" class="form-control" />
			</div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}