@model IEnumerable<dpsn_gestao_documentos_nauticos.ViewModel.EmbarcacaoViewModel>

@{
    ViewData["Title"] = "Embarcações Cadastradas";
}

<h2>Frota de Embarcações</h2>

<p>
    <a asp-action="Create">Cadastrar Nova Embarcação</a>
</p>

<table border="1" cellpadding="5" cellspacing="0">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Estaleiro (Construtor)</th>
            <th>Tipo</th>
            <th>Área de Navegação</th>
            <th>Comprimento</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" align="center">
                    Nenhum registro de embarcação encontrado no banco MongoDB.
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Nome</strong></td>
                    <td>@item.NomeEstaleiro</td>
                    <td>@item.TipoEmbarcacao</td>
                    <td>@item.AreaNavegacaoTipoServico</td>
                    <td>@item.ComprimentoTotal.ToString("F2") m</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IdEmbarcacao">Editar</a> |
                        <a asp-action="Delete" asp-route-id="@item.IdEmbarcacao">Excluir</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>