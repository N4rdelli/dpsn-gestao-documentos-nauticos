@model dpsn_gestao_documentos_nauticos.Models.Estaleiro

@{
    ViewData["Title"] = "Dados do Estaleiro";
}

<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Dados do Estaleiro</h1>
        <p class="text-sm text-slate-500">Dados cadastrais completos de @Model.NomeFantasia no sistema náutico.</p>
    </div>
    <div class="inline-flex space-x-2">
        <a asp-action="Index" class="px-4 py-2 text-sm font-medium text-slate-500 bg-slate-100 hover:bg-slate-200 rounded-md transition-colors">
            Voltar à Lista
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="px-4 py-2 text-sm font-medium text-white bg-sky-700 hover:bg-sky-800 rounded-md shadow-sm transition-all">
            Editar Informações
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex flex-col items-center text-center h-full">
        <div class="w-20 h-20 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center font-bold text-2xl border border-blue-100 shadow-inner mb-4">
            @(Model.NomeFantasia?.Substring(0, 2) ?? "ES")
        </div>
        <h2 class="text-lg font-bold text-slate-800">@Model.NomeFantasia</h2>
        <span class="text-xs bg-slate-100 text-slate-600 font-medium px-2.5 py-1 rounded-full mt-1.5">Perfil Estaleiro Parceiro</span>

        <div class="w-full border-t border-slate-100 my-5 pt-4 text-left space-y-3">
            <div>
                <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 block">E-mail de Login</span>
                <span class="text-sm text-slate-700 font-medium break-all">@Model.Email</span>
            </div>
            <div>
                <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 block">Telefone</span>
                <span class="text-sm text-slate-700 font-medium">@Model.Telefone</span>
            </div>
        </div>
    </div>

    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
            <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider border-b border-slate-100 pb-3 mb-4">Informações Institucionais</h3>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">Razão Social</dt>
                    <dd class="text-sm text-slate-800 mt-0.5">@Model.RazaoSocial</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">CNPJ</dt>
                    <dd class="text-sm text-slate-800 font-mono mt-0.5">@Model.Cnpj</dd>
                </div>
            </dl>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
            <h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider border-b border-slate-100 pb-3 mb-4">Localização & Endereço</h3>
            <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold text-slate-400 uppercase">Logradouro</dt>
                    <dd class="text-sm text-slate-800 mt-0.5">@Model.Endereco.Logradouro, @Model.Endereco.Numero</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">CEP</dt>
                    <dd class="text-sm text-slate-800 font-mono mt-0.5">@Model.Endereco.Cep</dd>
                </div>
                @if (!string.IsNullOrEmpty(Model.Endereco.Complemento))
                {
                    <div class="sm:col-span-3">
                        <dt class="text-xs font-semibold text-slate-400 uppercase">Complemento</dt>
                        <dd class="text-sm text-slate-800 mt-0.5">@Model.Endereco.Complemento</dd>
                    </div>
                }
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">Bairro</dt>
                    <dd class="text-sm text-slate-800 mt-0.5">@Model.Endereco.Bairro</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">Cidade</dt>
                    <dd class="text-sm text-slate-800 mt-0.5">@Model.Endereco.Cidade</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold text-slate-400 uppercase">Estado (UF)</dt>
                    <dd class="text-sm text-slate-800 mt-0.5 uppercase">@Model.Endereco.Estado</dd>
                </div>
            </dl>
        </div>
    </div>
</div>